  "keyFeatures": [
    "Comprehensive exercise database with images, GIFs, instructional blogs, and video links",
    "Filterable exercise search by body part, target muscle, equipment, and keyword",
    "Full workout routine library with categorization by goal, level, duration, and gender",
    "Category endpoints for body parts, target muscles, and equipment with exercise counts",
    "Rate limiting with tiered limits (20,000 req/15min general, 20 req/15min for routines)",
    "MongoDB backend via Prisma ORM with optimized indexes for fast filtering",
    "Docker support for easy deployment",
    "Security hardened with Helmet, CORS, and HSTS"
  ],
  "publicApiSurface": [
    "GET /api/v1/exercises",
    "GET /api/v1/exercises/:id",
    "GET /api/v1/bodyParts",
    "GET /api/v1/targetMuscles",
    "GET /api/v1/equipments",
    "GET /api/v1/routines",
    "GET /api/v1/routines/:id",
    "GET /health"
  ]
